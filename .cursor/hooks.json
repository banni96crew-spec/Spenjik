{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/before-shell.mjs",
        "timeout": 5
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/after-edit.mjs",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop.mjs",
        "timeout": 5
      }
    ]
  }
}
